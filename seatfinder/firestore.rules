rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: cafes
    // Fields: name, address, latitude, longitude, congestion, seatTypes, hasOutlets, hasWifi, atmosphere, imageUrl, aiPrediction
    //
    // Collection: cafes/{cafeId}/reviews
    // Fields: cafeId, userId, userName, rating, comment, createdAt
    //
    // Collection: users/{userId}/favorites
    // Fields: userId, cafeId, createdAt
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidCafe(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.latitude is number && data.longitude is number &&
             data.congestion in ['low', 'medium', 'high'];
    }

    function isValidReview(data) {
      return data.cafeId is string && data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 500;
    }

    match /cafes/{cafeId} {
      allow read: if true; // Publicly readable for seat finding
      allow write: if false; // Only admin or internal process should update cafe status in real app
    }

    match /cafes/{cafeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
    }
  }
}
